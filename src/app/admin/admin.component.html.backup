              <path d="M6.12499 11.9584L11.9583 6.12508C12.2309 5.85796 12.4478 5.53945 12.5965 5.18797C12.7453 4.83649 12.8228 4.45902 12.8247 4.07738C12.8267 3.69574 12.7529 3.3175 12.6078 2.96453C12.4626 2.61157 12.2489 2.29089 11.9791 2.02102C11.7092 1.75116 11.3885 1.53747 11.0355 1.39231C10.6826 1.24715 10.3043 1.1734 9.9227 1.17533C9.54106 1.17726 9.16358 1.25482 8.81211 1.40354C8.46063 1.55226 8.14212 1.76917 7.87499 2.04175L2.04166 7.87508C1.76908 8.14221 1.55216 8.46072 1.40345 8.8122C1.25473 9.16368 1.17717 9.54115 1.17524 9.92279C1.17331 10.3044 1.24706 10.6827 1.39222 11.0356C1.53738 11.3886 1.75107 11.7093 2.02093 11.9791C2.2908 12.249 2.61148 12.4627 2.96444 12.6079C3.31741 12.753 3.69564 12.8268 4.07728 12.8248C4.45893 12.8229 4.8364 12.7453 5.18788 12.5966C5.53936 12.4479 5.85787 12.231 6.12499 11.9584Z" stroke="#6A7282" stroke-width="1.16667" stroke-linecap="round" stroke-linejoin="round"/>
