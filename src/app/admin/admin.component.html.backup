          <path d="M18.3333 17.5001V15.8334C18.3328 15.0948 18.087 14.3774 17.6345 13.7937C17.182 13.2099 16.5485 12.793 15.8333 12.6084" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M13.3333 2.6084C14.0504 2.79198 14.6859 3.20898 15.1397 3.79366C15.5935 4.37833 15.8399 5.09742 15.8399 5.83757C15.8399 6.57771 15.5935 7.2968 15.1397 7.88147C14.6859 8.46615 14.0504 8.88315 13.3333 9.06673" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>User Management</span>
      </a>

      <a routerLink="/admin/appointments" routerLinkActive="nav-item-active" class="nav-item">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2.5" y="3.33333" width="15" height="15" rx="1.66667" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="13.3333" y1="1.66667" x2="13.3333" y2="5" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round"/>
          <line x1="6.66667" y1="1.66667" x2="6.66667" y2="5" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round"/>
          <line x1="2.5" y1="8.33333" x2="17.5" y2="8.33333" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round"/>
        </svg>
        <span>Appointments</span>
      </a>

      <a routerLink="/admin/medical" routerLinkActive="nav-item-active" class="nav-item">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.5 1.66675H5.00001C4.55798 1.66675 4.13406 1.84234 3.8215 2.1549C3.50894 2.46746 3.33334 2.89139 3.33334 3.33341V16.6667C3.33334 17.1088 3.50894 17.5327 3.8215 17.8453C4.13406 18.1578 4.55798 18.3334 5.00001 18.3334H15C15.442 18.3334 15.866 18.1578 16.1785 17.8453C16.4911 17.5327 16.6667 17.1088 16.6667 16.6667V5.83341L12.5 1.66675Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
